{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": true,
      "inputs": ["**/*.ts", "**/*.json", "eslint.config.ts"]
    }
  }
}
